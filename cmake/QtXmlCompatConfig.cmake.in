@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Qt@QT_VERSION_MAJOR@ COMPONENTS Core Xml)

if(Qt@QT_VERSION_MAJOR@_FOUND AND Qt@QT_VERSION_MAJOR@_VERSION_MAJOR GREATER_EQUAL 6)
	find_dependency(Qt@QT_VERSION_MAJOR@ COMPONENTS Core5Compat)
endif()

include(${CMAKE_CURRENT_LIST_DIR}/QtXmlCompatTargets.cmake)

check_required_components(QtXmlCompat)